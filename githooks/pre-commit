#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_cs_files="$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' || true)"
if [ -z "$staged_cs_files" ]; then
  exit 0
fi

echo "Running CSharpier on staged C# files..."

dotnet tool restore >/dev/null

printf '%s\n' "$staged_cs_files" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  dotnet dotnet-csharpier "$file"
  git add "$file"
done
