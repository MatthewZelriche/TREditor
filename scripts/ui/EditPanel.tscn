[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/EditPanel.cs" id="1_panel"]

[node name="Edit" type="PanelContainer"]
layout_mode = 2
script = ExtResource("1_panel")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="Scroll" type="ScrollContainer" parent="Margin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="Column" type="VBoxContainer" parent="Margin/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="OperationsTitle" type="Label" parent="Margin/Scroll/Column"]
layout_mode = 2
text = "OPERATIONS"

[node name="OperationGrid" type="GridContainer" parent="Margin/Scroll/Column"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 5
theme_override_constants/v_separation = 5
columns = 2

[node name="SectionSeparator" type="HSeparator" parent="Margin/Scroll/Column"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="OptionsTitle" type="Label" parent="Margin/Scroll/Column"]
layout_mode = 2
text = "OPTIONS"

[node name="NoOptions" type="Label" parent="Margin/Scroll/Column"]
layout_mode = 2
text = "Select an operation to view its settings."

[node name="ExtrudeOptions" type="HBoxContainer" parent="Margin/Scroll/Column"]
layout_mode = 2
visible = false

[node name="AlongFaceNormal" type="CheckBox" parent="Margin/Scroll/Column/ExtrudeOptions"]
layout_mode = 2
button_pressed = true
text = "Extrude along face normal"
tooltip_text = "Enabled: local extrusion along the selected face normal. Disabled: global extrusion along the gizmo drag direction."

[node name="InsetOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2
theme_override_constants/separation = 4

[node name="DepthRow" type="HBoxContainer" parent="Margin/Scroll/Column/InsetOptions"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="DepthLabel" type="Label" parent="Margin/Scroll/Column/InsetOptions/DepthRow"]
layout_mode = 2
text = "Depth"

[node name="Depth" type="HSlider" parent="Margin/Scroll/Column/InsetOptions/DepthRow"]
custom_minimum_size = Vector2(80, 0)
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.05
max_value = 4.0
step = 0.05
value = 0.25
tooltip_text = "Distance from each original edge to the inset edge."

[node name="DepthValue" type="Label" parent="Margin/Scroll/Column/InsetOptions/DepthRow"]
custom_minimum_size = Vector2(36, 0)
layout_mode = 2
text = "0.25"
horizontal_alignment = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/InsetOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/InsetOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the inset. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/InsetOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel the inset. Shortcut: Esc"

[node name="BevelOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2
theme_override_constants/separation = 4

[node name="WidthRow" type="HBoxContainer" parent="Margin/Scroll/Column/BevelOptions"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="WidthLabel" type="Label" parent="Margin/Scroll/Column/BevelOptions/WidthRow"]
layout_mode = 2
text = "Width"

[node name="Width" type="HSlider" parent="Margin/Scroll/Column/BevelOptions/WidthRow"]
custom_minimum_size = Vector2(80, 0)
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.05
max_value = 4.0
step = 0.05
value = 0.25
tooltip_text = "Distance cut back from the selection along its neighboring edges."

[node name="WidthValue" type="Label" parent="Margin/Scroll/Column/BevelOptions/WidthRow"]
custom_minimum_size = Vector2(36, 0)
layout_mode = 2
text = "0.25"
horizontal_alignment = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/BevelOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/BevelOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the bevel. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/BevelOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel the bevel. Shortcut: Esc"

[node name="CollapseVerticesOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2
theme_override_constants/separation = 4

[node name="TargetRow" type="HBoxContainer" parent="Margin/Scroll/Column/CollapseVerticesOptions"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="TargetLabel" type="Label" parent="Margin/Scroll/Column/CollapseVerticesOptions/TargetRow"]
layout_mode = 2
text = "Target"

[node name="Target" type="OptionButton" parent="Margin/Scroll/Column/CollapseVerticesOptions/TargetRow"]
layout_mode = 2
size_flags_horizontal = 3
tooltip_text = "Choose which selected vertex survives. Selection order determines first and second."

[node name="CentroidInfo" type="Label" parent="Margin/Scroll/Column/CollapseVerticesOptions"]
visible = false
layout_mode = 2
text = "Three or more vertices collapse at their centroid."
autowrap_mode = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/CollapseVerticesOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/CollapseVerticesOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the collapse. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/CollapseVerticesOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel collapsing the vertices. Shortcut: Esc"

[node name="BridgeEdgesOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2
theme_override_constants/separation = 4

[node name="SegmentsRow" type="HBoxContainer" parent="Margin/Scroll/Column/BridgeEdgesOptions"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="SegmentsLabel" type="Label" parent="Margin/Scroll/Column/BridgeEdgesOptions/SegmentsRow"]
layout_mode = 2
text = "Segments"

[node name="Segments" type="SpinBox" parent="Margin/Scroll/Column/BridgeEdgesOptions/SegmentsRow"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 1.0
max_value = 64.0
step = 1.0
value = 4.0
tooltip_text = "Number of quads across the bridge."

[node name="AngleRow" type="HBoxContainer" parent="Margin/Scroll/Column/BridgeEdgesOptions"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="AngleLabel" type="Label" parent="Margin/Scroll/Column/BridgeEdgesOptions/AngleRow"]
layout_mode = 2
text = "Arch"

[node name="Angle" type="HSlider" parent="Margin/Scroll/Column/BridgeEdgesOptions/AngleRow"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.0
max_value = 180.0
step = 5.0
value = 180.0
tooltip_text = "Total circular sweep: 0° is flat and 180° is semicircular."

[node name="AngleValue" type="Label" parent="Margin/Scroll/Column/BridgeEdgesOptions/AngleRow"]
custom_minimum_size = Vector2(36, 0)
layout_mode = 2
text = "180°"
horizontal_alignment = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/BridgeEdgesOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/BridgeEdgesOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the bridge. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/BridgeEdgesOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel bridging the edges. Shortcut: Esc"

[node name="FillHoleOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/FillHoleOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/FillHoleOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the filled face. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/FillHoleOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel filling the hole. Shortcut: Esc"

[node name="CollapseFaceOptions" type="VBoxContainer" parent="Margin/Scroll/Column"]
visible = false
layout_mode = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Scroll/Column/CollapseFaceOptions"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 4

[node name="Apply" type="Button" parent="Margin/Scroll/Column/CollapseFaceOptions/Actions"]
layout_mode = 2
text = "Apply"
tooltip_text = "Commit the collapsed face. Shortcut: Enter"

[node name="Cancel" type="Button" parent="Margin/Scroll/Column/CollapseFaceOptions/Actions"]
layout_mode = 2
text = "Cancel"
tooltip_text = "Cancel collapsing the face. Shortcut: Esc"
