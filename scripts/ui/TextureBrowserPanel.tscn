[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/TextureBrowserPanel.cs" id="1_panel"]

[node name="Textures" type="PanelContainer"]
layout_mode = 2
script = ExtResource("1_panel")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="Column" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Active" type="HBoxContainer" parent="Margin/Column"]
layout_mode = 2

[node name="Preview" type="TextureRect" parent="Margin/Column/Active"]
custom_minimum_size = Vector2(72, 72)
layout_mode = 2
expand_mode = 1
stretch_mode = 5

[node name="Details" type="VBoxContainer" parent="Margin/Column/Active"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Title" type="Label" parent="Margin/Column/Active/Details"]
layout_mode = 2
text = "Active Texture"

[node name="Path" type="Label" parent="Margin/Column/Active/Details"]
layout_mode = 2
size_flags_vertical = 3
text = "No active texture"
autowrap_mode = 2

[node name="RootPath" type="Label" parent="Margin/Column"]
layout_mode = 2
text = "Texture folder: Not configured"
autowrap_mode = 2

[node name="Actions" type="HBoxContainer" parent="Margin/Column"]
layout_mode = 2

[node name="ChooseFolder" type="Button" parent="Margin/Column/Actions"]
layout_mode = 2
text = "Choose Folder"

[node name="ClearFolder" type="Button" parent="Margin/Column/Actions"]
layout_mode = 2
text = "Clear"

[node name="Refresh" type="Button" parent="Margin/Column/Actions"]
layout_mode = 2
text = "Refresh"

[node name="Search" type="LineEdit" parent="Margin/Column"]
layout_mode = 2
placeholder_text = "Search textures..."

[node name="Status" type="Label" parent="Margin/Column"]
layout_mode = 2
text = "Choose a texture folder to begin."
autowrap_mode = 2

[node name="Scroll" type="ScrollContainer" parent="Margin/Column"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="Grid" type="HFlowContainer" parent="Margin/Column/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 6

[node name="FolderDialog" type="FileDialog" parent="."]
title = "Select Texture Folder"
size = Vector2i(900, 600)
file_mode = 2
access = 2
use_native_dialog = true
